{
  "name": "xrtl-terminal",
  "version": "1.0.0",
  "description": "A modern SSH terminal application based on VSCode architecture",
  "main": "build/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "webpack --watch --config webpack.main.config.js",
    "dev:renderer": "webpack-dev-server --config webpack.renderer.config.js",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "webpack --config webpack.main.config.js",
    "build:renderer": "webpack --config webpack.renderer.config.js",
    "start": "electron .",
    "test": "jest",
    "lint": "eslint src/**/*.ts src/**/*.tsx",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "ssh",
    "terminal",
    "electron",
    "xterm"
  ],
  "author": "XRTL Team",
  "license": "MIT",
  "build": {
    "appId": "com.xrtl.terminal",
    "productName": "XRTL Terminal",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "node_modules/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/fonts",
        "to": "fonts"
      },
      {
        "from": "resources/icons",
        "to": "icons"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icons/logo.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icons/logo.ico",
      "uninstallerIcon": "resources/icons/logo.ico",
      "installerHeaderIcon": "resources/icons/logo.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "XRTL Terminal"
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "keytar": "^7.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rxjs": "^7.8.1",
    "ssh2": "^1.16.0",
    "ssh2-sftp-client": "^11.0.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.15.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "electron": "^31.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.34.2",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^29.7.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.1.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
