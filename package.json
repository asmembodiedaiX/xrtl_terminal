{
  "name": "xrtl-terminal",
  "version": "1.0.0",
  "description": "A modern SSH terminal application based on VSCode architecture",
  "main": "build/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "webpack --watch --config webpack.main.config.js",
    "dev:renderer": "webpack-dev-server --config webpack.renderer.config.js",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "webpack --config webpack.main.config.js",
    "build:renderer": "webpack --config webpack.renderer.config.js",
    "start": "electron .",
    "test": "jest",
    "lint": "eslint src/**/*.ts src/**/*.tsx",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "ssh",
    "terminal",
    "electron",
    "xterm"
  ],
  "author": "XRTL Team",
  "license": "MIT",
  "build": {
    "appId": "com.xrtl.terminal",
    "productName": "XRTL Terminal",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "node_modules/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/fonts",
        "to": "fonts"
      },
      {
        "from": "resources/icons",
        "to": "icons"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "resources/icons/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icons/logo.ico",
      "uninstallerIcon": "resources/icons/logo.ico",
      "installerHeaderIcon": "resources/icons/logo.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "XRTL Terminal"
    }
  },
  "dependencies": {
    "ansi-parser": "^3.2.1",
    "keytar": "^7.9.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "rxjs": "^7.8.0",
    "sqlite3": "^5.0.0",
    "ssh2": "^1.15.0",
    "ssh2-sftp-client": "^9.0.0",
    "xterm": "^5.0.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/sqlite3": "^3.1.8",
    "@types/ssh2": "^1.11.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.0.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.32.0",
    "html-webpack-plugin": "^5.0.0",
    "jest": "^29.0.0",
    "style-loader": "^3.0.0",
    "ts-jest": "^29.0.0",
    "ts-loader": "^9.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0",
    "webpack-dev-server": "^4.0.0"
  }
}
